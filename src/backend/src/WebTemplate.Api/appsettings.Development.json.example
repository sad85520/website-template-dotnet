{
  "_comment": "複製為 appsettings.Development.json 後，替換所有 __REPLACE_WITH_*__ 佔位符為 local 真實值；此檔已被 .gitignore 排除，切勿提交包含真實 secret 的副本。",
  "ConnectionStrings": {
    "DefaultConnection": "Server=mssql;Database=WebTemplate;User=sa;Password=__REPLACE_WITH_LOCAL_SA_PASSWORD__;TrustServerCertificate=true"
  },
  "Jwt": {
    "Secret": "__REPLACE_WITH_LOCAL_JWT_SECRET_AT_LEAST_32_CHARS__"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  }
}
