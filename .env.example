# Docker Compose 環境變數範本
# 複製此檔案為 .env 並填入實際值

# ========== Database ==========
# 將 <REPLACE_ME> 改為你「個人產生」的強密碼，不要沿用文件範例或 Slack 群組共用值。
# 簡易產法（PowerShell / Bash 任一）：
#   powershell: [guid]::NewGuid().ToString("N")
#   bash:       openssl rand -hex 24
#   python:     python -c "import secrets; print(secrets.token_urlsafe(32))"
# MSSQL 密碼政策：至少 8 字、含大小寫 + 數字 + 符號；上述 openssl/guid 皆符合。
DB_PASSWORD=<REPLACE_ME>
# 整個連線字串可在 docker-compose 或部署環境以 ConnectionStrings__DefaultConnection
# 覆寫；預設由 appsettings.Development.json 提供，指向 compose 內的 mssql 服務。

# ========== JWT ==========
# 同樣由個人產生，勿沿用範例值；JWT Secret 必須 ≥ 32 字元（256-bit）。
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#   openssl rand -base64 48
JWT_SECRET=<REPLACE_ME_MIN_32_CHARS>
# Production 透過 ASP.NET Core 環境變數綁定：
#   Jwt__Secret / Jwt__Issuer / Jwt__Audience
# 可以用環境變數覆寫 appsettings.json 內同名設定（__ 代表 JSON 巢狀）

# ========== Application ==========
ASPNETCORE_ENVIRONMENT=Development
# 生產請設為 Production；同時務必透過環境變數設定 AllowedHosts（分號分隔），
# 例如：AllowedHosts=api.example.com;www.example.com

# ========== Serilog ==========
# Logging 設定走 appsettings.{Environment}.json；如需臨時壓低雜訊，可覆寫：
#   Serilog__MinimumLevel__Default=Warning

# ========== Frontend (Vite) ==========
# 前端建置期 API base url；在 CI/compose 依環境覆寫
# VITE_API_BASE_URL=http://localhost:5000
